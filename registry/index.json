{
    "version": 1,
    "workers": {
        "image-resize": {
            "type": "binary",
            "description": "III engine image resize worker",
            "repo": "iii-hq/workers",
            "tag_prefix": "image-resize",
            "supported_targets": ["aarch64-apple-darwin", "x86_64-unknown-linux-gnu"],
            "has_checksum": true,
            "default_config": {
                "name": "image-resize",
                "config": {
                    "width": 200,
                    "height": 200,
                    "strategy": "scale-to-fit",
                    "quality": {
                        "jpeg": 85,
                        "webp": 80
                    }
                }
            },
            "version": "0.1.2"
        },
        "todo-worker": {
            "description": "Quickstart CRUD todo worker using the Node.js iii SDK",
            "image": "docker.io/andersonofl/todo-worker",
            "repo": "iii-hq/workers",
            "default_config": {
                "name": "todo-worker",
                "config": {
                    "III_URL": "ws://localhost:49134"
                }
            },
            "version": "0.1.0",
            "latest": "latest"
        }
    }
}
