{
    "version": 1,
    "workers": {
        "image-resize": {
            "description": "III engine image resize worker",
            "repo": "iii-hq/workers",
            "tag_prefix": "image-resize",
            "supported_targets": ["aarch64-apple-darwin", "x86_64-unknown-linux-gnu"],
            "has_checksum": true,
            "default_config": {
                "class": "workers::image_resize::ImageResizeWorker",
                "config": {
                    "width": 200,
                    "height": 200,
                    "strategy": "scale-to-fit",
                    "quality": {
                        "jpeg": 85,
                        "webp": 80
                    }
                }
            },
            "version": "0.1.2"
        },
        "nanochat": {
            "description": "Karpathy's nanochat LLM worker — train, fine-tune, evaluate, and chat with GPT models",
            "repo": "iii-hq/workers",
            "tag_prefix": "nanochat",
            "language": "python",
            "supported_targets": ["any"],
            "has_checksum": false,
            "default_config": {
                "source": "sft",
                "device": "auto",
                "engine_url": "ws://localhost:49134"
            },
            "version": "0.1.0"
        }
    }
}
