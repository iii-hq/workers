      "repo": "iii-hq/workers",
      "tag_prefix": "image-resize",
      "supported_targets": ["aarch64-apple-darwin", "x86_64-unknown-linux-gnu"],
      "has_checksum": true,
      "default_config": {
        "name": "image-resize",
        "config": {
          "width": 200,
          "height": 200,
          "strategy": "scale-to-fit",
          "quality": {
            "jpeg": 85,
            "webp": 80
          }
        }
      },
      "version": "0.1.2"
    },
    "iii-lsp": {
      "type": "binary",
