{
  "version": 1,
  "workers": {
    "auth-credentials": {
      "type": "binary",
      "description": "Provider credential vault under auth::* — API keys and OAuth tokens",
      "repo": "iii-hq/workers",
      "tag_prefix": "auth-credentials",
      "supported_targets": ["aarch64-apple-darwin", "x86_64-unknown-linux-gnu"],
      "has_checksum": true,
      "default_config": {},
      "version": "0.1.0"
    },
    "auth-rbac": {
      "type": "binary",
      "description": "HMAC API keys and workspace roles (owner/admin/member/viewer) under auth::rbac::*",
      "repo": "iii-hq/workers",
      "tag_prefix": "auth-rbac",
      "supported_targets": ["aarch64-apple-darwin", "x86_64-unknown-linux-gnu"],
      "has_checksum": true,
      "default_config": {},
      "version": "0.1.0"
    },
    "document-extract": {
      "type": "binary",
      "description": "PDF/Word text extraction under document::extract for agent context ingestion",
      "repo": "iii-hq/workers",
      "tag_prefix": "document-extract",
      "supported_targets": ["aarch64-apple-darwin", "x86_64-unknown-linux-gnu"],
      "has_checksum": true,
      "default_config": {},
      "version": "0.1.0"
    },
    "guardrails": {
      "type": "binary",
      "description": "Local heuristics for PII, leaked API keys, jailbreak keywords, and toxicity under guardrails::*",
      "repo": "iii-hq/workers",
      "tag_prefix": "guardrails",
      "supported_targets": ["aarch64-apple-darwin", "x86_64-unknown-linux-gnu"],
      "has_checksum": true,
      "default_config": {},
      "version": "0.1.0"
    },
    "image-resize": {
      "type": "binary",
